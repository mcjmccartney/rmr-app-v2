# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Calendar API Configuration
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----"
GOOGLE_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Application Configuration
NEXT_PUBLIC_BASE_URL=https://raising-my-rescue.vercel.app

# Make.com Webhook URLs
NEXT_PUBLIC_MAKE_WEBHOOK_SESSION_URL=https://hook.eu1.make.com/your_session_webhook_path

# n8n Webhook URLs (parallel mirror of Make.com during migration)
NEXT_PUBLIC_N8N_SESSION_WEBHOOK_URL=https://n8n.srv836498.hstgr.cloud/webhook-test/your_n8n_webhook_path
NEXT_PUBLIC_MAKE_WEBHOOK_BOOKING_URL=https://hook.eu1.make.com/your_booking_webhook_path
NEXT_PUBLIC_MAKE_WEBHOOK_PDF_URL=https://hook.eu1.make.com/your_pdf_webhook_path
NEXT_PUBLIC_MAKE_WEBHOOK_BOOKING_TERMS_URL=https://hook.eu1.make.com/your_booking_terms_webhook_path

# Environment
NODE_ENV=production

# Security Configuration (REQUIRED for production)
# Webhook Authentication - protects webhook endpoints from unauthorized access
WEBHOOK_API_KEY=your_secure_random_api_key_here
WEBHOOK_SECRET=your_secure_random_secret_here

# Generate secure random keys using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =====================================================
# SECURITY NOTES
# =====================================================
#
# PUBLIC vs PRIVATE Variables:
# ----------------------------
# NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# Only use NEXT_PUBLIC_ prefix for truly public data:
#   ✅ NEXT_PUBLIC_SUPABASE_URL - Safe (public endpoint)
#   ✅ NEXT_PUBLIC_SUPABASE_ANON_KEY - Safe (public key with RLS)
#   ✅ NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN - Safe (public token, restrict by URL)
#   ✅ NEXT_PUBLIC_BASE_URL - Safe (public URL)
#
# NEVER use NEXT_PUBLIC_ for:
#   ❌ SUPABASE_SERVICE_ROLE_KEY - Server-side only!
#   ❌ GOOGLE_PRIVATE_KEY - Server-side only!
#   ❌ WEBHOOK_API_KEY - Server-side only!
#   ❌ WEBHOOK_SECRET - Server-side only!
#
# Best Practices:
# ---------------
# - Never commit actual environment variables to version control
# - Use Vercel's environment variables dashboard for production
# - Ensure GOOGLE_PRIVATE_KEY includes proper line breaks
# - Keep all keys secure and rotate them regularly (every 90 days)
# - Use different keys for development and production environments
# - WEBHOOK_API_KEY and WEBHOOK_SECRET are CRITICAL for production security
# - Generate strong random values for all secrets (minimum 32 characters)
# - Enable 2FA on Supabase, Vercel, and Google Cloud accounts
# - Monitor Vercel logs for unauthorized access attempts
# - Set up alerts for failed authentication attempts
